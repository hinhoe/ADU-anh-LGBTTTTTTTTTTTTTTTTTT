<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Algorithm_Benchmark_Tool.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Algorithm_Benchmark_Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Algorithm-Benchmark-Tool">

    <Grid Background="#10131a">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <local:SidebarControl
    x:Name="Sidebar"
    Grid.Column="0"/>
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <Grid Padding="0, 0, 0, 20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <local:HeaderControl Grid.Row="0" Margin="0,0,0,20"/>
            <Grid Grid.Row="1" ColumnSpacing="20" RowSpacing="20" Padding="20,0,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                    <local:HeaderControl 
                        x:Name="HeaderCtrl" 
                        Grid.Row="0" 
                        Margin="0,0,0,20"/>

                    <local:AnalyticsChartControl 
                        x:Name="Charts" 
                        Grid.Row="2" 
                        Padding="20" 
                        Margin="20,20,20,10"/>
                
                    <local:AlgorithmCardControl
                        x:Name="BubbleCard"
                        Grid.Row="0"
                        Grid.Column="0"/>

                    <local:AlgorithmCardControl
                        x:Name="QuickCard"
                        Grid.Row="0"
                        Grid.Column="1"/>

                    <local:AlgorithmCardControl
                        x:Name="MergeCard"
                        Grid.Row="1"
                        Grid.Column="0"/>

                    <local:AlgorithmCardControl
                        x:Name="InsertionCard"
                        Grid.Row="1"
                        Grid.Column="1"/>

                    <local:AlgorithmCardControl
                        x:Name="ShellCard"
                        Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"/>

                </Grid>
                <local:AnalyticsChartControl Grid.Row="2" Padding="20" Margin="20, 20, 20, 10"/>
        </Grid>
        </ScrollViewer>
    </Grid>
</Window>
