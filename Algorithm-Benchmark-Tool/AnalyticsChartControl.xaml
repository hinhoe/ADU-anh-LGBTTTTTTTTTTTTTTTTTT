<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Algorithm_Benchmark_Tool.AnalyticsChartControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Algorithm_Benchmark_Tool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="Phân tích thời gian thực"
            Foreground="white"
            FontSize="24"
            FontWeight="Bold"
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Margin="0,0,0,10"/>

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#161B22" CornerRadius="8"
                    BorderBrush="#30363D" BorderThickness="1" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="180"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Margin="0,0,0,10"
                               Text="So sánh theo thời gian"
                               Foreground="#94a3b8" FontSize="14"
                               FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <Border Grid.Row="1" BorderBrush="#30363D" BorderThickness="1"
                            CornerRadius="4" Background="#10131a">
                        <Canvas x:Name="ComparisonsCanvas"
                                MinHeight="160"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#161B22" CornerRadius="8"
                    BorderBrush="#30363D" BorderThickness="1" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="180"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Margin="0,0,0,10"
                               Text="Số lần hoán đổi"
                               Foreground="#94a3b8" FontSize="14"
                               FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <Border Grid.Row="1" BorderBrush="#30363D" BorderThickness="1"
                            CornerRadius="4" Background="#10131a">
                        <Canvas x:Name="SwapsCanvas"
                                MinHeight="160"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center" Margin="0,10,0,0">
            <Ellipse Width="12" Height="12" Fill="#3b82f6"/>
            <TextBlock Text="Bubble Sort" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <Ellipse Width="12" Height="12" Fill="#8b5cf6"/>
            <TextBlock Text="Insertion Sort" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <Ellipse Width="12" Height="12" Fill="#22c55e"/>
            <TextBlock Text="Quick Sort" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <Ellipse Width="12" Height="12" Fill="#facc15"/>
            <TextBlock Text="Merge Sort" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <Ellipse Width="12" Height="12" Fill="Red"/>
            <TextBlock Text="Shell Sort" VerticalAlignment="Center" Margin="0,0,5,0"/>
        </StackPanel>
    </Grid>
</UserControl>